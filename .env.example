# InvestSmart GitHub Deploy Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# Your GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
# Scopes needed: repo (full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub repository in format: username/reponame
# Example: VinupaHelitha/investsmart
GITHUB_REPO=username/investsmart

# Branch to deploy to (default: main)
GITHUB_BRANCH=main

# Comma-separated list of files to push
# Paths are relative to this script's directory
FILES_TO_PUSH=app.py,requirements.txt

# ─────────────────────────────────────────────────
# InvestSmart Application Configuration
# ─────────────────────────────────────────────────

# Your Streamlit Cloud deployment URL
# Example: https://investsmart-xxxxx.streamlit.app
# Optional: If not set, defaults to the hardcoded production URL
APP_URL=https://investsmart-xxxxx.streamlit.app
