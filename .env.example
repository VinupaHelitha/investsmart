# ============================================================
# InvestSmart — Environment Variables Template
# Copy this file to: .env
# Then fill in your real values (keep .env private — Never upload to GitHub!)
# ============================================================

# ── AI PROVIDERS ─────────────────────────────────────────────
# PRIMARY AI: Anthropic Claude (claude-sonnet-4-6)
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# SECONDARY AI: OpenAI GPT-4o
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# FALLBACK AI: Google Gemini 1.5 Flash (free tier — 1,500 req/day)
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-key-here

# ── DATABASE (SUPABASE) ──────────────────────────────────────
# Get both from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9-your-anon-key-here

# ── GRAPH DATABASE (NEO4J AURA) ───────────────────────────────
# Get from: https://console.neo4j.io → Your AuraDB Free instance
# URI looks like: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-aura-password-here

# ── DATA APIs ────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data)
# Get key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key-here

# NewsAPI (news headlines — 100 calls/day free)
# Get key from: https://newsapi.org/register
NEWS_API_KEY=your-newsapi-key-here

# ── NOTES ────────────────────────────────────────────────────
# yfinance (Yahoo Finance) — NO KEY NEEDED, completely free
# World Bank API           — NO KEY NEEDED, completely free
# GDELT Project            — NO KEY NEEDED, completely free
# Streamlit Community Cloud, GitHub Actions, Supabase, Neo4j Aura
#   — all free tiers, no credit card required
